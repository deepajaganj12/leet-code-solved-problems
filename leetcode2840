#include <iostream>
#include <string>
using namespace std;

class Solution {
public:
    bool checkStrings(string s1, string s2) {
        int freq[52] = {};

        for (int i = 0; i < s1.length(); i++) {
            int off = (i & 1) * 26;
            freq[s1[i] - 'a' + off]++;
            freq[s2[i] - 'a' + off]--;
        }

        for (int i = 0; i < 52; i++)
            if (freq[i] != 0) return false;

        return true;
    }
};

int main() {
    Solution obj;

    string s1, s2;
    cout << "Enter first string: ";
    cin >> s1;
    cout << "Enter second string: ";
    cin >> s2;

    if (s1.length() != s2.length()) {
        cout << "Strings are NOT equal (different lengths)" << endl;
        return 0;
    }

    bool result = obj.checkStrings(s1, s2);

    if (result)
        cout << "Strings are equivalent under allowed operations." << endl;
    else
        cout << "Strings are NOT equivalent." << endl;

    return 0;
}
