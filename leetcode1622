#include <bits/stdc++.h>
using namespace std;

class Fancy {
private:
    const int mod = 1e9 + 7;
    vector<long long> val;
    long long a, b;

    long long modPow(long long x, long long y, long long mod) {
        long long res = 1;
        x = x % mod;

        while (y > 0) {
            if (y % 2 == 1) {
                res = (res * x) % mod;
            }
            y = y / 2;
            x = (x * x) % mod;
        }
        return res;
    }

public:
    Fancy() {
        a = 1;
        b = 0;
    }

    void append(int value) {
        long long x = (value - b + mod) % mod;
        val.push_back((x * modPow(a, mod - 2, mod)) % mod);
    }

    void addAll(int inc) {
        b = (b + inc) % mod;
    }

    void multAll(int m) {
        a = (a * m) % mod;
        b = (b * m) % mod;
    }

    int getIndex(int idx) {
        if (idx >= val.size())
            return -1;

        return (a * val[idx] + b) % mod;
    }
};

int main() {

    Fancy* obj = new Fancy();

    obj->append(2);      // [2]
    obj->addAll(3);      // [5]
    obj->append(7);      // [5,7]
    obj->multAll(2);     // [10,14]

    cout << obj->getIndex(0) << endl; // 10

    obj->addAll(3);      // [13,17]
    obj->append(10);     // [13,17,10]

    cout << obj->getIndex(1) << endl; // 17
    cout << obj->getIndex(2) << endl; // 10

    return 0;
}
