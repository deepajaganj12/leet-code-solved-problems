#include <iostream>
#include <string>
using namespace std;

class Solution {
public:
    bool rotateString(string& s, string& goal) {
        return s.size() == goal.size() && (s + s).find(goal) != string::npos;
    }
};

int main() {
    Solution obj;

    string s, goal;
    cout << "Enter string s: ";
    cin >> s;
    cout << "Enter string goal: ";
    cin >> goal;

    if (obj.rotateString(s, goal)) {
        cout << "True" << endl;
    } else {
        cout << "False" << endl;
    }

    return 0;
}
